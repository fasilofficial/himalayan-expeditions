---
import { Head } from '@/components/Head';
import AppRouter from '@/components/Router';
import { expeditions } from '@/data/siteContent';
import '@/styles/global.css';

export function getStaticPaths() {
  return [
    { params: { slug: undefined } },
    { params: { slug: 'expeditions' } },
    ...expeditions.map((expedition) => ({
      params: { slug: `expeditions/${expedition._id}` },
    })),
    { params: { slug: 'gallery' } },
    { params: { slug: 'about' } },
    { params: { slug: 'contact' } },
    { params: { slug: 'admin-cms' } },
  ];
}
---

<html lang="en" class="w-full h-full">
  <head>
    <Head />
  </head>
  <body class="w-full h-full">
    <div id="root" class="w-full h-full">
      <AppRouter client:only="react" />
    </div>

    <div class="fixed bottom-6 right-6 z-50 flex flex-col gap-3">
      <a
        href="https://instagram.com"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Follow us on Instagram"
        class="floating-btn group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
        </svg>
      </a>

      <a
        href="https://wa.me/977123456789"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Chat with us on WhatsApp"
        class="floating-btn group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
      </a>
    </div>
  </body>
</html>

<style>
.floating-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  color: #111;
  border: 1px solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  transition: all 0.25s ease;
}

.floating-btn:hover {
  transform: translateY(-4px);
  background: rgba(255, 255, 255, 0.35);
}
</style>
